SECRET_KEY=gitvision-secret-key-12345
DB_HOST=localhost
DB_PORT=5432
DB_NAME=GitVision
DB_USER=postgres
DB_PASSWORD=0987654321

# Firebase Admin SDK: path to service account JSON, OR inline JSON in FIREBASE_CREDENTIALS_JSON
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_CREDENTIALS_JSON=
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
BACKUP_STORAGE_PREFIX=gitvision-backups/

# Opaque session token length (bytes before url-safe encoding)
SESSION_TOKEN_BYTES=32
