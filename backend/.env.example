SECRET_KEY=change-me

DB_HOST=localhost
DB_PORT=5432
DB_NAME=gitvision
DB_USER=postgres
DB_PASSWORD=postgres

# Firebase Admin SDK: path to service account JSON, OR inline JSON in FIREBASE_CREDENTIALS_JSON
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_CREDENTIALS_JSON=
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
BACKUP_STORAGE_PREFIX=gitvision-backups/

# Opaque session token length (bytes before url-safe encoding)
SESSION_TOKEN_BYTES=32

# Optional GitHub Personal Access Token for import endpoint rate limits
GITHUB_API_TOKEN=
